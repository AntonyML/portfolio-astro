---
interface Props {
   title: string;
   description: string;
   image: string;
}

const { title, description, image } = Astro.props;
---

<a
   href={`/${image}`}
   class='group relative w-full h-[400px] rounded-3xl overflow-hidden border border-white/5 bg-[#0a0a0a] shadow-lg hover:shadow-2xl hover:border-white/10 transition-all duration-500 block'
   transition:name={`image-${image}`}
>
   <!-- Fondo de Imagen con Zoom suave al Hover -->
   <div class='absolute inset-0 overflow-hidden'>
      <!-- Usamos img tag para mejor control de object-fit -->
      <img
         src={`/${image}.jpg`}
         alt={title}
         class='w-full h-full object-cover transition-transform duration-700 group-hover:scale-110 opacity-60 group-hover:opacity-40'
      />
      <!-- Gradiente superpuesto para legibilidad -->
      <div class='absolute inset-0 bg-gradient-to-t from-black via-zinc-950/80 to-transparent'></div>
   </div>

   <!-- Contenido -->
   <div class='absolute inset-0 p-8 flex flex-col justify-end z-10'>
      <!-- Título -->
      <h3 class='text-2xl font-bold text-white mb-3 tracking-tight group-hover:text-zinc-100 transition-colors line-clamp-2'>
         {title}
      </h3>

      <!-- Descripción (Limitada para evitar desbordes con line-clamp) -->
      <p class='text-zinc-400 text-sm leading-relaxed mb-6 line-clamp-3 group-hover:text-zinc-300 transition-colors'>
         {description}
      </p>

      <!-- Botón simulado -->
      <div class='inline-flex items-center gap-2 text-sm font-medium text-emerald-400 opacity-90 group-hover:opacity-100 transform translate-y-2 group-hover:translate-y-0 transition-all duration-300'>
         Ver detalles
         <svg xmlns='http://www.w3.org/2000/svg' width='16' height='16' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round' class='transition-transform group-hover:translate-x-1'><path d='M5 12h14'/><path d='m12 5 7 7-7 7'/></svg>
      </div>
   </div>
</a>

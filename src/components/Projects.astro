---
import { projects } from '../assets/data';
import ProjectCard from './ProjectCard.astro';
---

<section class='py-20 relative scroll-mt-36' id='projects'>
   <!-- Header con estilo consistente (Igual a Technologies/About) -->
   <div class='max-w-6xl mx-auto px-5 mb-12'>
      <div class='flex items-center justify-center md:justify-start gap-3 mb-3'>
            <div class='h-px w-8 bg-zinc-700'></div>
            <span class='text-zinc-500 text-xs font-bold uppercase tracking-widest'>Proyectos</span>
         </div>
      <h2 class='text-center md:text-left text-3xl md:text-4xl font-bold text-white tracking-tight'>
         Casos de Estudio de <span class='text-transparent bg-clip-text bg-gradient-to-r from-zinc-200 to-zinc-500'>Ingenieria</span>
      </h2>
      <p class='text-center md:text-left text-zinc-400 mt-2 max-w-2xl'>
         Decisiones arquitectonicas, trade-offs tecnicos e impacto real de cada sistema.
      </p>
   </div>

   <!-- Grid de Proyectos -->
   <div class='grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 max-w-6xl mx-auto px-5'>
      {
         projects.map((card) => (
            <ProjectCard
               id={card.id}
               title={card.title}
               type={card.type}
               role={card.role}
               description={card.description}
               highlights={card.highlights}
               stack={card.stack}
               image={card.image}
               color={card.color}
            />
         ))
      }
   </div>
</section>

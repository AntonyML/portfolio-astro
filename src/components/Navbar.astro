---
const { pathname } = Astro.url;

const socials = [
   { logo: "bx bxl-github", href: "https://github.com/AntonyML" },
   {
      logo: "bx bxl-linkedin-square",
      href: "https://www.linkedin.com/in/antony-monge-lopez/",
   },
   { logo: "bx bxl-instagram", href: "https://www.instagram.com/tony_m_l_/" },
   {
      logo: "bx bxl-facebook-circle",
      href: "https://www.facebook.com/tony.ml.786149",
   },
];

const navItems = [
   { text: "Inicio", href: "#home", modal: false },
   { text: "Experiencia laboral", href: "#experience", modal: false },
   { text: "Proyectos", href: "#projects", modal: false },
   { text: "Perfil", href: "#about", modal: false },
   { text: "Contacto", href: "#", modal: true },
];
---

<nav
   class="w-full h-16 bg-[#0a0a0a]/60 backdrop-blur-xl border-b border-white/5 text-white flex items-center px-6 py-3 fixed top-0 z-50 justify-between transition-all duration-300"
>
   <!-- Socials -->
   <ul class="flex items-center gap-5 hidden md:flex">
      {
         socials.map((social) => (
            <li>
               <a
                  href={social.href}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-2xl text-zinc-400 hover:text-white hover:scale-110 duration-300 ease-in-out cursor-pointer transition-all"
               >
                  <i class={social.logo} />
               </a>
            </li>
         ))
      }
   </ul>

   <!-- Nav Links -->
   <ul class="flex items-center gap-4 sm:gap-6 md:gap-8 mx-auto md:mx-0">
      {
         pathname === "/" &&
            navItems.map((item) => (
               <li>
                  {item.modal ? (
                     <button
                        data-contact-open
                        class="text-xs sm:text-sm whitespace-nowrap font-medium text-zinc-400 hover:text-white hover:scale-105 duration-300 transition-all font-sans cursor-pointer"
                     >
                        {item.text}
                     </button>
                  ) : (
                     <a
                        class="text-xs sm:text-sm whitespace-nowrap font-medium text-zinc-400 hover:text-white hover:scale-105 duration-300 transition-all font-sans"
                        href={item.href}
                     >
                        {item.text}
                     </a>
                  )}
               </li>
            ))
      }
   </ul>
</nav>

<script>
   // Smooth scrolling default behavior override to ensuring finding targets
   document.querySelectorAll('a[href^="#"]').forEach((anchor) => {
      anchor.addEventListener("click", (e) => {
         e.preventDefault();
         const href = anchor.getAttribute("href");
         if (!href) return;

         const target = document.querySelector(href);
         if (target) {
            // Fix for form section scrolling - scroll to container to show title
            if (href === "#form") {
               const section = target.closest("section");
               if (section) {
                  section.scrollIntoView({ behavior: "smooth" });
                  return;
               }
            }

            target.scrollIntoView({
               behavior: "smooth",
            });
         } else if (href === "#technologies") {
            // Fallback for Technologies section identification
            const headings = Array.from(document.querySelectorAll("h2"));
            const techHeading = headings.find(
               (h) =>
                  h.textContent.includes("Stack") ||
                  h.textContent.includes("Tecnologías"),
            );
            techHeading
               ?.closest("section")
               ?.scrollIntoView({ behavior: "smooth" });
         }
      });
   });
</script>

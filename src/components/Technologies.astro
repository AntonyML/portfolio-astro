---
import { technologies } from '../assets/data';
import TechnologyCard from './TechnologyCard.astro';
---

<section class='py-20 relative overflow-hidden'>
   <!-- Header Minimalista -->
   <div class='max-w-6xl mx-auto px-5 mb-12'>
      <h2 class='text-center md:text-left text-3xl md:text-4xl font-bold text-white tracking-tight'>
         Stack <span class='text-transparent bg-clip-text bg-gradient-to-r from-zinc-200 to-zinc-500'>Tecnológico</span>
      </h2>
      <p class='text-center md:text-left text-zinc-400 mt-2 max-w-2xl'>
         Herramientas y tecnologías que potencian mis desarrollos.
      </p>
   </div>

   <!-- Slider Infinito -->
   <!-- Shader Mask-->
   <div class='relative max-w-5xl mx-auto mask-linear-fade overflow-hidden'>
      <div class='flex w-max items-center gap-4 animate-infinite-scroll hover:pause-animation'>
         <!-- Renderizar 2 veces para loop perfecto -->
         {
            technologies.map((tech) => (
               <TechnologyCard text={tech.text} logo={tech.logo} />
            ))
         }
         {
            technologies.map((tech) => (
               <TechnologyCard text={tech.text} logo={tech.logo} />
            ))
         }
      </div>
   </div>

   <div class='flex justify-center mt-12'>
      <button
         data-tech-btn
         class='group relative px-6 py-2.5 bg-white/5 border border-white/10 rounded-full overflow-hidden transition-all hover:bg-white/10 hover:border-white/20'
      >
         <span class='relative z-10 text-sm font-medium text-zinc-300 group-hover:text-white transition-colors'>
            Explorar todo el stack
         </span>
      </button>
   </div>

   <!-- Nativo Glassmorphism -->
   <div
      class='fixed inset-0 z-[100] bg-black/80 backdrop-blur-md hidden justify-center items-center opacity-0 transition-opacity duration-300'
      data-tech-modal
   >
      <div
         class='w-11/12 max-w-5xl max-h-[80vh] bg-[#09090b] border border-white/10 rounded-[2rem] p-8 md:p-12 overflow-y-auto relative shadow-2xl'
         data-tech-stop
      >
     
         <div class='flex justify-between items-center mb-8'>
             <h3 class='text-2xl font-bold text-white'>Tecnologías</h3>
             <button class='p-2 rounded-full hover:bg-white/10 transition-colors text-zinc-400 hover:text-white' data-close-modal>
                 <svg xmlns='http://www.w3.org/2000/svg' width='24' height='24' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round'><line x1='18' y1='6' x2='6' y2='18'></line><line x1='6' y1='6' x2='18' y2='18'></line></svg>
             </button>
         </div>

         <!-- Grid de Tecnologías -->
         <div class='flex flex-wrap justify-center gap-4'>
            {
               technologies.map((tech) => (
                  <TechnologyCard text={tech.text} logo={tech.logo} />
               ))
            }
         </div>
      </div>
   </div>
</section>

<style>
   .mask-linear-fade {
      mask-image: linear-gradient(to right, transparent 0%, black 20%, black 80%, transparent 100%);
      -webkit-mask-image: linear-gradient(to right, transparent 0%, black 20%, black 80%, transparent 100%);
   }

   @keyframes infinite-scroll {
      from { transform: translateX(0); }
      to { transform: translateX(-50%); }
   }

   .animate-infinite-scroll {
      animation: infinite-scroll 60s linear infinite;
   }

   .hover\:pause-animation:hover {
      animation-play-state: paused;
   }
   .modal-enter {
      opacity: 1 !important;
   }
</style>

<script>
   const btn = document.querySelector('[data-tech-btn]');
   const modal = document.querySelector('[data-tech-modal]');
   const closeBtn = document.querySelector('[data-close-modal]');
   const stop = document.querySelector('[data-tech-stop]');

   function openModal() {
      modal?.classList.remove('hidden');
      requestAnimationFrame(() => {
          modal?.classList.add('flex', 'modal-enter');
      });
   }

   function closeModal() {
      modal?.classList.remove('modal-enter');
      setTimeout(() => {
          modal?.classList.remove('flex');
          modal?.classList.add('hidden');
      }, 300);
   }

   btn?.addEventListener('click', openModal);
   closeBtn?.addEventListener('click', closeModal);
   
   modal?.addEventListener('click', (e) => {
      if (e.target === modal) closeModal();
   });
   
   // Cerrar con Escape
   document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !modal?.classList.contains('hidden')) {
         closeModal();
      }
   });
</script>

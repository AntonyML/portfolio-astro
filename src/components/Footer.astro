---
const socials = [
   { logo: 'bx bxl-github', href: 'https://github.com/AntonyML' },
   { logo: 'bx bxl-linkedin-square', href: 'https://www.linkedin.com/in/antony-monge-lopez/' },
   { logo: 'bx bxl-instagram', href: 'https://www.instagram.com/tony_m_l_/' },
   { logo: 'bx bxl-facebook-circle', href: 'https://www.facebook.com/tony.ml.786149' }
];
---

<footer class="w-full bg-[#0a0a0a] pt-12 pb-8 relative overflow-hidden">

    <div class="max-w-5xl mx-auto px-5 relative z-10">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-10 mb-12">

            <!-- Branding -->
            <div class="space-y-4">
                <a href="#home" class="text-xl font-bold text-transparent bg-clip-text bg-gradient-to-r from-white to-zinc-500">
                    Antony.dev
                </a>
                <p class="text-zinc-500 text-sm leading-relaxed">
                    Construyendo software con proposito. Especializado en aplicaciones escalables y arquitecturas robustas.
                </p>
                <div class="flex gap-3 pt-1">
                    {socials.map((social) => (
                        <a
                            href={social.href}
                            target="_blank"
                            rel="noopener noreferrer"
                            class="w-9 h-9 flex items-center justify-center rounded-xl bg-white/5 border border-white/5 text-zinc-400 hover:bg-white/10 hover:text-white hover:border-white/10 transition-all duration-300 group"
                        >
                            <i class={`${social.logo} text-lg group-hover:scale-110 transition-transform`}></i>
                        </a>
                    ))}
                </div>
            </div>

            <!-- Navegacion -->
            <div>
                <h4 class="text-white text-sm font-semibold mb-5 uppercase tracking-widest">Navegacion</h4>
                <ul class="space-y-2.5">
                    <li><a href="#home"         class="text-zinc-500 hover:text-white transition-colors text-sm">Inicio</a></li>
                    <li><a href="#experience"   class="text-zinc-500 hover:text-white transition-colors text-sm">Experiencia laboral</a></li>
                    <li><a href="#projects"     class="text-zinc-500 hover:text-white transition-colors text-sm">Proyectos</a></li>
                    <li><a href="#about"        class="text-zinc-500 hover:text-white transition-colors text-sm">Perfil</a></li>
                    
                </ul>
            </div>

            <!-- Contacto -->
            <div>
                <h4 class="text-white text-sm font-semibold mb-5 uppercase tracking-widest">Contacto</h4>
                <ul class="space-y-2.5">
                    <li>
                        <a href="mailto:antonymonge18@gmail.com" class="text-zinc-500 hover:text-white transition-colors text-sm flex items-center gap-2">
                            <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                            antony.mongelopez@ucr.ac.cr
                        </a>
                    </li>
                    <li class="text-zinc-600 text-sm flex items-center gap-2">
                        <span class="w-1.5 h-1.5 rounded-full bg-emerald-500/70"></span>
                        Disponible para nuevos retos
                    </li>
                </ul>
            </div>

        </div>

        <!-- Bottom Bar -->
        <div class="border-t border-white/5 pt-6 flex flex-col md:flex-row justify-between items-center gap-3">
            <p class="text-zinc-600 text-xs text-center md:text-left">
                &copy; 2026 Antony Monge. Todos los derechos reservados.
            </p>
            <span class="text-zinc-700 text-xs flex items-center gap-1.5">
                Hecho con <i class='bx bxs-heart text-red-500/40 text-sm'></i> y Astro
            </span>
        </div>
    </div>

</footer>
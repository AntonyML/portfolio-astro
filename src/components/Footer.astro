---
const socials = [
   { logo: 'bx bxl-github', href: 'https://github.com/AntonyML' },
   { logo: 'bx bxl-linkedin-square', href: 'https://www.linkedin.com/in/antony-monge-lopez/' },
   { logo: 'bx bxl-instagram', href: 'https://www.instagram.com/tony_m_l_/' },
   { logo: 'bx bxl-facebook-circle', href: 'https://www.facebook.com/tony.ml.786149' }
];
---

<footer class="w-full bg-[#0a0a0a] border-t border-white/5 pt-16 pb-8 relative overflow-hidden">
    <!-- Luz ambiente inferior sutil -->
    <div class="absolute -top-[200px] left-1/2 -translate-x-1/2 w-[600px] h-[300px] bg-white/5 rounded-full blur-[120px] pointer-events-none opacity-20"></div>

    <div class="max-w-6xl mx-auto px-5 relative z-10">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 mb-16">
            
            <!-- Branding -->
            <div class="space-y-4">
                <a href="#home" class="text-2xl font-bold bg-clip-text text-transparent bg-gradient-to-r from-white to-zinc-500">
                    Antony.dev
                </a>
                <p class="text-zinc-500 text-sm leading-relaxed">
                    Construyendo software con propósito. Especializado en aplicaciones escalables y arquitecturas robustas.
                </p>
            </div>

            <!-- Links Rápidos -->
            <div>
                <h4 class="text-white font-semibold mb-6">Navegación</h4>
                <ul class="space-y-3">
                    <li><a href="#home" class="text-zinc-500 hover:text-white transition-colors text-sm">Inicio</a></li>
                    <li><a href="#about" class="text-zinc-500 hover:text-white transition-colors text-sm">Sobre mí</a></li>
                    <li><a href="#projects" class="text-zinc-500 hover:text-white transition-colors text-sm">Proyectos</a></li>
                    <li><a href="#technologies" class="text-zinc-500 hover:text-white transition-colors text-sm">Stack</a></li>
                </ul>
            </div>

            <!-- Contacto Info -->
            <div>
                <h4 class="text-white font-semibold mb-6">Contacto</h4>
                <ul class="space-y-3">
                    <li>
                        <a href="mailto:contacto@antonymonge.com" class="text-zinc-500 hover:text-white transition-colors text-sm flex items-center gap-2">
                             Envía un correo
                        </a>
                    </li>
                    <li class="text-zinc-500 text-sm">
                        Disponible para nuevos retos
                    </li>
                </ul>
            </div>

            <!-- Social -->
            <div>
                <h4 class="text-white font-semibold mb-6">Sígueme</h4>
                <div class="flex gap-3">
                     {
                        socials.map((social) => (
                            <a
                                href={social.href}
                                target="_blank"
                                rel="noopener noreferrer"
                                class="w-10 h-10 flex items-center justify-center rounded-xl bg-white/5 border border-white/5 text-zinc-400 hover:bg-white/10 hover:text-white hover:border-white/10 transition-all duration-300 group"
                            >
                                <i class={`${social.logo} text-xl group-hover:scale-110 transition-transform`}></i>
                            </a>
                        ))
                    }
                </div>
            </div>
        </div>

        <!-- Bottom Bar -->
        <div class="border-t border-white/5 pt-8 flex flex-col md:flex-row justify-between items-center gap-4">
            <p class="text-zinc-600 text-sm text-center md:text-left">
                &copy; 2026 Antony Monge. Todos los derechos reservados.
            </p>
            
            <div class="flex items-center gap-6 text-sm text-zinc-600">
                <span class="flex items-center gap-1">
                    Hecho con <i class='bx bxs-heart text-red-500/50'></i> y Astro
                </span>
            </div>
        </div>
    </div>
</footer>
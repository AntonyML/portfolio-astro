
<!--- Monochrome Glassmorphism (Refinado para B&W y UX Premium)
     - Diseño minimalista, elegante y tecnológico.
     - Paleta de colores: Escala de grises, Argent y Negro Profundo para armonizar con la foto.
     - Sin colores invasivos que choquen con el B&W.
-->
<article class='w-full min-h-[600px] py-16 px-5 flex justify-center items-center relative overflow-hidden'>
   <!-- Iluminación Ambiental (Sutil y Elegante) -->
   <!-- Focos de luz blanca suave para dar profundidad sin color invasivo -->
   <div class='absolute top-0 left-1/4 w-96 h-96 bg-white/5 rounded-full blur-[120px] -z-10 animate-pulse'></div>
   <div class='absolute bottom-0 right-1/4 w-96 h-96 bg-zinc-500/10 rounded-full blur-[120px] -z-10'></div>

   <!-- Tarjeta Principal (Frosted Glass) -->
   <div class='w-full max-w-6xl bg-[#0a0a0a]/40 backdrop-blur-xl border border-white/5 rounded-[2rem] p-8 md:p-16 flex flex-col md:flex-row items-center gap-12 md:gap-20 shadow-2xl relative'>
      
      <!-- Decoración sutil de borde brillante -->
      <div class='absolute inset-0 rounded-[2rem] border border-white/5 pointer-events-none'></div>
      
      <!-- Columna de Texto -->
      <div class='flex-1 space-y-6 text-center md:text-left z-10'>
         <div class='inline-flex items-center gap-2 px-4 py-1.5 bg-white/5 text-zinc-300 rounded-full text-xs font-semibold tracking-wide uppercase border border-white/10 hover:bg-white/10 transition-colors'>
            <span class='w-1.5 h-1.5 rounded-full bg-emerald-500 animate-pulse'></span>
            Disponible para colaborar
         </div>
         
         <div class='space-y-2'>
            <h1 class='font-bold text-4xl sm:text-5xl lg:text-6xl leading-tight text-white tracking-tight'>
               Ingeniería de software <br class='hidden lg:block'/>
               <span class='text-transparent bg-clip-text bg-gradient-to-r from-white via-zinc-200 to-zinc-500'>
                  con visión sólida.
               </span>
            </h1>
         </div>

         <p class='text-zinc-400 text-lg sm:text-xl leading-relaxed max-w-2xl mx-auto md:mx-0'>
            Construyo soluciones escalables que no solo funcionan hoy, 
            sino que están diseñadas para perdurar y evolucionar.
         </p>
      </div>

      <!-- Columna de Imagen (Enmarcada y Estilizada) -->
      <div class='relative group'>
         <!-- Efecto de brillo posterior (Glow) sutil -->
         <div class='absolute -inset-4 bg-gradient-to-b from-white/10 to-transparent rounded-full blur-2xl opacity-0 group-hover:opacity-100 transition duration-700'></div>
         
         <!-- Contenedor de la Imagen -->
         <!-- Mantenemos la forma rectangular/vertical de la foto original pero suavizada -->
         <div class='relative w-72 h-[450px] sm:w-80 sm:h-[500px] md:w-[350px] md:h-[550px] rounded-2xl overflow-hidden border border-white/10 bg-gradient-to-b from-zinc-800/50 to-black shadow-2xl'>
            <!-- La imagen se muestra completa, sin cortes extraños -->
            <!-- object-cover para asegurar que llene el espacio, pero object-center para centrar el rostro -->
            <img 
               src='/image-black-white-removebg-preview.png' 
               alt='Antony Profile' 
               class='w-full h-full object-cover object-top transition-transform duration-700 group-hover:scale-105'
            >
            
            <!-- Overlay sutil degradado en la parte inferior para integrar con el fondo oscuro -->
            <div class='absolute inset-0 bg-gradient-to-t from-black/80 via-transparent to-transparent opacity-60'></div>
         </div>
         
         <!-- Elemento decorativo flotante (opcional, icono o detalle minimalista) -->
         <div class='absolute -bottom-6 -right-6 w-24 h-24 bg-zinc-900/80 backdrop-blur-md border border-white/5 rounded-2xl md:flex items-center justify-center shadow-xl p-4 hidden'>
             <span class='text-4xl text-white grayscale opacity-80 hover:grayscale-0 hover:opacity-100 transition-all duration-300'></span>
         </div>
      </div>

   </div>
</article>

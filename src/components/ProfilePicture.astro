<!-- OPCIÓN 4: Tarjeta Glassmorphism (Tecnológico)
     - Contenido encapsulado en una "tarjeta" semitransparente.
     - Se siente muy moderno y organizado.
-->

<article class="w-full py-20 px-5 flex justify-center items-center relative overflow-hidden">
   !-- Elementos decorativos de fondo --
   <div class="absolute top-10 left-10 w-72 h-72 bg-purple-500/20 rounded-full blur-[100px] -z-10"></div>
   <div class="absolute bottom-10 right-10 w-72 h-72 bg-blue-500/20 rounded-full blur-[100px] -z-10"></div>

   <div class="w-full max-w-5xl bg-white/5 backdrop-blur-lg border border-white/10 rounded-3xl p-8 md:p-12 flex flex-col md:flex-row items-center gap-10 shadow-2xl">
      <div class="flex-1 space-y-4 text-center md:text-left">
         <div class="inline-block px-3 py-1 bg-blue-500/10 text-blue-400 rounded-full text-sm font-medium mb-2 border border-blue-500/20">
            Developer Portfolio
         </div>
         <h1 class="font-bold text-3xl sm:text-5xl leading-tight">
            Ingeniería de software con visión de futuro.
         </h1>
         <p class="text-white/60 text-lg">
            Creo soluciones escalables que transforman negocios y mejoran vidas.
         </p>
      </div>

      <div class="w-48 h-48 sm:w-64 sm:h-64 flex-shrink-0 relative">
         <div class="absolute inset-0 bg-gradient-to-tr from-blue-500 to-purple-500 rounded-2xl rotate-6 opacity-50"></div>
         <img 
            src="/image-black-white-removebg-preview.png" 
            alt="Profile" 
            class="absolute inset-0 w-full h-full object-cover object-top rounded-2xl border-2 border-white/10 bg-[#1e1e1e] shadow-xl"
         >
      </div>
   </div>
</article>


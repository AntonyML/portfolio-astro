---
import SafeImage from './SafeImage.astro';
---
<article class='w-full pt-4 pb-0 px-5 flex justify-center items-center relative overflow-hidden z-30'>
   <!-- Iluminación Ambiental Localizada -->
   <div class='absolute top-20 left-1/4 w-72 h-72 bg-white/5 rounded-full blur-[100px] -z-10 animate-pulse'></div>
   <div class='absolute bottom-10 right-1/4 w-72 h-72 bg-zinc-500/10 rounded-full blur-[100px] -z-10'></div>

   <!-- Tarjeta Principal (Frosted Glass) -->
   <div class='w-full max-w-5xl bg-[#0a0a0a]/60 backdrop-blur-2xl border border-white/5 rounded-[2rem] p-6 md:p-10 flex flex-col md:flex-row items-center gap-6 md:gap-12 shadow-2xl relative'>
      
      <!-- Decoración sutil de borde brillante -->
      <div class='absolute inset-0 rounded-[2rem] border border-white/5 pointer-events-none'></div>
      
      <!-- Columna de Texto -->
      <div class='flex-1 space-y-4 text-center md:text-left z-10'>
         <div class='inline-flex items-center gap-2 px-3 py-1 bg-white/5 text-zinc-300 rounded-full text-[10px] font-semibold tracking-wide uppercase border border-white/10 hover:bg-white/10 transition-colors'>
            <span class='w-1.5 h-1.5 rounded-full bg-emerald-500 animate-pulse'></span>
            Disponible para trabajar
         </div>
         
         <div class='space-y-1'>
            <h1 class='font-bold text-3xl sm:text-4xl lg:text-5xl leading-tight text-white tracking-tight'>
               Desarrollo software <br class='hidden lg:block'/>
               <span class='text-transparent bg-clip-text bg-gradient-to-r from-white via-zinc-200 to-zinc-500'>
                  con enfoque en calidad y escala.
               </span>
            </h1>
         </div>

         <p class='text-zinc-400 text-base sm:text-lg leading-relaxed max-w-xl mx-auto md:mx-0'>
            Diseño y construyo sistemas digitales pensados para crecer,
            integrarse y mantenerse en el tiempo.
         </p>

         <!-- CTAs -->
         <div class='flex flex-wrap gap-3 justify-center md:justify-start pt-2'>
            <button
               data-contact-open
               class='flex items-center gap-2 px-5 py-2.5 rounded-full text-sm font-semibold bg-white text-black hover:bg-zinc-200 transition-all duration-300 hover:scale-[1.03] cursor-pointer'
            >
               <svg xmlns='http://www.w3.org/2000/svg' width='15' height='15' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2.5' stroke-linecap='round' stroke-linejoin='round'><path d='M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z'/><polyline points='22,6 12,13 2,6'/></svg>
               Contáctame
            </button>
            <a
               href='https://www.linkedin.com/in/antony-monge-lopez/'
               target='_blank'
               rel='noopener noreferrer'
               class='flex items-center gap-2 px-5 py-2.5 rounded-full text-sm font-semibold bg-white/5 border border-white/10 text-zinc-200 hover:bg-white/10 hover:border-white/20 transition-all duration-300 hover:scale-[1.03]'
            >
               <i class='bx bxl-linkedin-square text-base'></i>
               LinkedIn
            </a>
         </div>

      </div>

      <!-- Columna de Imagen -->
      <div class='relative group'>
         <div class='absolute -inset-4 bg-gradient-to-b from-white/10 to-transparent rounded-full blur-2xl opacity-0 group-hover:opacity-100 transition duration-700'></div>
         
         <div class='relative w-56 h-[320px] sm:w-64 sm:h-[380px] md:w-[280px] md:h-[400px] rounded-2xl overflow-hidden border border-white/10 bg-gradient-to-b from-zinc-800/50 to-black shadow-2xl'>
            <SafeImage 
               imageName="image-profile" 
               alt="Antony Profile" 
               class="w-full h-full object-cover object-top transition-all duration-1000 group-hover:scale-105 grayscale opacity-80" data-grayscale-reveal data-reveal-delay="600" />
            <div class='absolute inset-0 bg-gradient-to-t from-black/80 via-transparent to-transparent opacity-60'></div>
         </div>
      </div>

   </div>
</article>

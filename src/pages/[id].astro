---
const { id } = Astro.params;
import Layout from '../layouts/Layout.astro';
import { projects, buttons, experience } from '../assets/data';
import TechChip from '../components/TechChip.astro';

export function getStaticPaths() {
   return projects.map((project) => ({
      params: { id: project.image },
   }));
}

const card = projects.find((p) => p.image === id);
const job  = experience.find((e) => e.image === id);

if (!card) {
   return Astro.redirect('/');
}
---

<Layout title={`${card.title} | Portfolio`}>

   <!-- Background -->
   <div class='fixed inset-0 z-[-1]' style={`--ctx: ${card.color}`}>
      <img src={`/${id}.webp`} alt='' id='fade-image'
         class='absolute inset-0 w-full h-full object-cover opacity-10 scale-90 blur-xl transition-all duration-700' />
      <div class='absolute inset-0 bg-gradient-to-br from-[var(--ctx)]/10 via-zinc-950 to-zinc-950'></div>
   </div>

   <main class='min-h-screen px-6 py-24 max-w-5xl mx-auto' transition:name={`image-${id}`}>

      <!-- Back -->
      <a href='/#projects'
         class='inline-flex items-center gap-2 text-sm font-medium text-zinc-500 hover:text-white transition-colors duration-200 mb-10'>
         <i class={`${buttons[0].back} text-base`}></i>
         Volver a casos de estudio
      </a>

      <div class='flex flex-col lg:flex-row gap-10 items-start'>

         <!-- Imagen sticky sidebar -->
         <div class='w-full lg:w-72 xl:w-80 shrink-0 lg:sticky lg:top-24'>
            <img src={`/${id}.webp`} alt={card.title}
               class='w-full rounded-2xl object-cover object-top shadow-2xl ring-1 ring-white/10' />
            <div class='mt-4 flex flex-col gap-2'>
               {(card.githubFront || card.githubBack) ? (
                  <>
                     {card.githubFront && (
                        <a href={card.githubFront} target='_blank' rel='noopener noreferrer'
                           class='flex items-center justify-center gap-2 w-full px-5 py-2.5 rounded-xl text-sm font-semibold text-white transition-all duration-300 hover:brightness-110'
                           style={`background-color: ${card.color}`}>
                           <i class={`${buttons[0].github} text-base`}></i>
                           Frontend
                        </a>
                     )}
                     {card.githubBack && (
                        <a href={card.githubBack} target='_blank' rel='noopener noreferrer'
                           class='flex items-center justify-center gap-2 w-full px-5 py-2.5 rounded-xl text-sm font-semibold text-white transition-all duration-300 hover:brightness-110'
                           style={`background-color: ${card.color}99`}>
                           <i class={`${buttons[0].github} text-base`}></i>
                           Backend
                        </a>
                     )}
                  </>
               ) : card.github ? (
                  <a href={card.github} target='_blank' rel='noopener noreferrer'
                     class='flex items-center justify-center gap-2 w-full px-5 py-2.5 rounded-xl text-sm font-semibold text-white transition-all duration-300 hover:brightness-110'
                     style={`background-color: ${card.color}`}>
                     <i class={`${buttons[0].github} text-base`}></i>
                     Ver Repositorio
                  </a>
               ) : (
                  <span class='flex items-center justify-center gap-2 w-full px-5 py-2.5 rounded-xl text-sm font-semibold text-white/25 cursor-not-allowed border border-white/8'
                     title='Repositorio privado'>
                     <i class={`${buttons[0].github} text-base`}></i>
                     Repositorio privado
                  </span>
               )}
            </div>
         </div>

         <!-- Contenido principal -->
         <div class='flex flex-col gap-7 flex-1 min-w-0'>

            <!-- Badges -->
            <div class='flex flex-wrap items-center gap-2'>
               <span class='px-3 py-1 rounded-full text-[10px] font-bold tracking-widest uppercase text-white'
                  style={`background-color: ${card.color}30; border: 1px solid ${card.color}60;`}>
                  {card.type}
               </span>
               {job && (
                  <span class='px-3 py-1 rounded-full text-[10px] font-bold tracking-widest uppercase text-emerald-400 bg-emerald-400/10 border border-emerald-400/30'>
                     Proyecto Pagado
                  </span>
               )}
               <span class='text-xs text-zinc-500 font-medium'>{card.role}</span>
            </div>

            <!-- Titulo -->
            <h1 class='text-3xl sm:text-4xl font-black leading-tight text-white -mt-2'>{card.title}</h1>

            <!-- Descripcion -->
            <p class='text-zinc-300 text-sm sm:text-base leading-relaxed'>{card.description}</p>

            <!-- Contexto tecnico (solo proyectos pagados) -->
            {job && (
               <div class='rounded-2xl bg-white/3 border border-white/8 px-5 py-4'>
                  <p class='text-[10px] font-bold uppercase tracking-widest text-zinc-500 mb-2'>Contexto tecnico</p>
                  <p class='text-zinc-300 text-sm leading-relaxed'>{job.context}</p>
               </div>
            )}

            <!-- Impacto (solo proyectos pagados) -->
            {job && (
               <div class='rounded-2xl px-5 py-4'
                  style={`background-color: ${card.color}10; border: 1px solid ${card.color}30`}>
                  <p class='text-[10px] font-bold uppercase tracking-widest mb-2' style={`color: ${card.color}`}>Impacto</p>
                  <p class='text-zinc-200 text-sm leading-relaxed'>{job.impact}</p>
               </div>
            )}

            <!-- ═══ Engineering Case Study Sections ═══ -->

            {card.challenge && (
               <div class='rounded-2xl bg-white/3 border border-white/8 px-5 py-4'>
                  <p class='text-[10px] font-bold uppercase tracking-widest text-zinc-500 mb-2'>Desafio de Negocio</p>
                  <p class='text-zinc-300 text-sm leading-relaxed'>{card.challenge}</p>
               </div>
            )}

            {card.solution && (
               <div class='rounded-2xl bg-white/3 border border-white/8 px-5 py-4'>
                  <p class='text-[10px] font-bold uppercase tracking-widest mb-2' style={`color: ${card.color}`}>Solucion de Ingenieria</p>
                  <p class='text-zinc-300 text-sm leading-relaxed'>{card.solution}</p>
               </div>
            )}

            {card.architecture && (
               <div class='rounded-2xl bg-white/3 border border-white/8 px-5 py-4'>
                  <p class='text-[10px] font-bold uppercase tracking-widest text-zinc-500 mb-2'>Arquitectura y Decisiones Tecnicas</p>
                  <p class='text-zinc-300 text-sm leading-relaxed'>{card.architecture}</p>
               </div>
            )}

            {card.testing && (
               <div class='rounded-2xl px-5 py-4'
                  style={`background-color: ${card.color}08; border: 1px solid ${card.color}20`}>
                  <p class='text-[10px] font-bold uppercase tracking-widest mb-2' style={`color: ${card.color}`}>Testing y Aseguramiento de Calidad</p>
                  <p class='text-zinc-300 text-sm leading-relaxed'>{card.testing}</p>
               </div>
            )}

            {card.management && (
               <div class='rounded-2xl bg-white/3 border border-white/8 px-5 py-4'>
                  <p class='text-[10px] font-bold uppercase tracking-widest text-zinc-500 mb-2'>Gestion del Proyecto</p>
                  <p class='text-zinc-300 text-sm leading-relaxed'>{card.management}</p>
               </div>
            )}

            {card.impact && (
               <div class='rounded-2xl px-5 py-4'
                  style={`background-color: ${card.color}10; border: 1px solid ${card.color}30`}>
                  <p class='text-[10px] font-bold uppercase tracking-widest mb-2' style={`color: ${card.color}`}>Impacto y Resultados</p>
                  <p class='text-zinc-200 text-sm leading-relaxed'>{card.impact}</p>
               </div>
            )}

            {card.artifacts && card.artifacts.length > 0 && (
               <div class='rounded-2xl bg-white/3 border border-white/8 px-5 py-4'>
                  <p class='text-[10px] font-bold uppercase tracking-widest text-zinc-500 mb-3'>Artefactos de Ingenieria</p>
                  <div class='flex flex-wrap gap-2'>
                     {card.artifacts.map((artifact) => (
                        <span class='px-3 py-1 rounded-full text-xs font-medium text-zinc-300 bg-white/5 border border-white/10'>
                           {artifact}
                        </span>
                     ))}
                  </div>
               </div>
            )}

            <!-- Puntos clave -->
            <div>
               <p class='text-[10px] font-bold uppercase tracking-widest text-zinc-500 mb-3'>Puntos clave</p>
               <ul class='grid grid-cols-1 sm:grid-cols-2 gap-2.5'>
                  {(job ? job.highlights : card.highlights).map((h) => (
                     <li class='flex items-start gap-2.5 text-sm text-zinc-300'>
                        <svg class='mt-0.5 shrink-0' style={`color: ${card.color}`}
                           xmlns='http://www.w3.org/2000/svg' width='14' height='14'
                           viewBox='0 0 24 24' fill='none' stroke='currentColor'
                           stroke-width='2.5' stroke-linecap='round' stroke-linejoin='round'>
                           <path d='M20 6 9 17l-5-5'/>
                        </svg>
                        {h}
                     </li>
                  ))}
               </ul>
            </div>

            <!-- Stack -->
            <div>
               <p class='text-[10px] font-bold uppercase tracking-widest text-zinc-500 mb-3'>Stack tecnologico</p>
               <div class='flex flex-wrap gap-2'>
                  {card.stack.map((tech) => (<TechChip tech={tech} />))}
               </div>
            </div>

         </div>
      </div>
   </main>
</Layout>

   <!-- ═══ Main Layout ═══════════════════════════════════════════════════════ -->
   <main
      class='min-h-screen flex flex-col lg:flex-row items-center justify-center gap-10 px-6 py-24 max-w-6xl mx-auto'
      transition:name={`image-${id}`}
   >

      <!-- ── Imagen del Proyecto ──────────────────────────────────────────── -->
      <div class='w-full max-w-sm lg:max-w-md shrink-0'>
         <img
            src={`/${id}.webp`}
            alt={card.title}
            class='w-full rounded-2xl object-cover object-top shadow-2xl ring-1 ring-white/10 hover:scale-[102%] transition-transform duration-300'
         />
      </div>

      <!-- ── Panel de Información ────────────────────────────────────────── -->
      <div class='flex flex-col gap-5 max-w-xl w-full'>

         <!-- Tipo + Rol -->
         <div class='flex flex-wrap items-center gap-3'>
            <span
               class='px-3 py-1 rounded-full text-[10px] font-bold tracking-widest uppercase text-white'
               style={`background-color: ${card.color}35; border: 1px solid ${card.color}70;`}
            >
               {card.type}
            </span>
            <span class='text-xs text-zinc-400 font-medium tracking-wide'>{card.role}</span>
         </div>

         <!-- Título -->
         <h1 class='text-3xl sm:text-4xl font-black leading-tight text-white'>
            {card.title}
         </h1>

         <!-- Descripción -->
         <p class='text-zinc-300 text-sm sm:text-base leading-relaxed'>
            {card.description}
         </p>

         <!-- Highlights -->
         <ul class='flex flex-col gap-2'>
            {card.highlights.map((h) => (
               <li class='flex items-start gap-2.5 text-sm text-zinc-300'>
                  <svg
                     class='mt-0.5 shrink-0'
                     style={`color: ${card.color}`}
                     xmlns='http://www.w3.org/2000/svg' width='16' height='16'
                     viewBox='0 0 24 24' fill='none' stroke='currentColor'
                     stroke-width='2.5' stroke-linecap='round' stroke-linejoin='round'
                  >
                     <path d='M20 6 9 17l-5-5'/>
                  </svg>
                  {h}
               </li>
            ))}
         </ul>

         <!-- Stack -->
         <div class='flex flex-wrap gap-2 pt-1'>
            {card.stack.map((tech) => (
               <TechChip tech={tech} />
            ))}
         </div>

         <!-- Acciones -->
         <div class='flex items-center gap-5 pt-2'>
            <a
               href='/#projects'
               class='flex items-center gap-2 text-sm font-medium text-zinc-400 hover:text-white transition-colors duration-200'
            >
               <i class={`${buttons[0].back} text-base`}></i>
               Volver a casos de estudio
            </a>

            {(card.githubFront || card.githubBack) ? (
               <>
                  {card.githubFront && (
                     <a
                        href={card.githubFront}
                        target='_blank'
                        rel='noopener noreferrer'
                        class='flex items-center gap-2 px-5 py-2 rounded-full text-sm font-semibold text-white transition-all duration-300 hover:brightness-110 hover:scale-[1.03]'
                        style={`background-color: ${card.color}`}
                     >
                        <i class={`${buttons[0].github} text-base`}></i>
                        Frontend
                     </a>
                  )}
                  {card.githubBack && (
                     <a
                        href={card.githubBack}
                        target='_blank'
                        rel='noopener noreferrer'
                        class='flex items-center gap-2 px-5 py-2 rounded-full text-sm font-semibold text-white transition-all duration-300 hover:brightness-110 hover:scale-[1.03]'
                        style={`background-color: ${card.color}99`}
                     >
                        <i class={`${buttons[0].github} text-base`}></i>
                        Backend
                     </a>
                  )}
               </>
            ) : card.github ? (
               <a
                  href={card.github}
                  target='_blank'
                  rel='noopener noreferrer'
                  class='flex items-center gap-2 px-5 py-2 rounded-full text-sm font-semibold text-white transition-all duration-300 hover:brightness-110 hover:scale-[1.03]'
                  style={`background-color: ${card.color}`}
               >
                  <i class={`${buttons[0].github} text-base`}></i>
                  Ver Repositorio
               </a>
            ) : (
               <span
                  class='flex items-center gap-2 px-5 py-2 rounded-full text-sm font-semibold text-white/30 cursor-not-allowed border border-white/10'
                  title='Repositorio privado o no disponible'
               >
                  <i class={`${buttons[0].github} text-base`}></i>
                  Repositorio privado
               </span>
            )}
         </div>

      </div>
   </main>
</Layout>

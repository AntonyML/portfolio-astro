---
const { id } = Astro.params;
import Layout from '../layouts/Layout.astro';
import { projects, buttons } from '../assets/data';

export function getStaticPaths() {
   return projects.map((project) => ({
      params: { id: project.image },
   }));
}

const card = projects.find((p) => p.image === id);

if (!card) {
   return Astro.redirect('/');
}
---

<Layout title={`${card.title} | Portfolio`}>
   <!-- ═══ Background layer ═══════════════════════════════════════════════════ -->
   <div
      class='fixed inset-0 z-[-1]'
      style={`--ctx: ${card.color}`}
   >
      <img
         src={`/${id}.jpg`}
         alt=''
         id='fade-image'
         class='absolute inset-0 w-full h-full object-cover opacity-10 scale-90 blur-xl transition-all duration-700'
      />
      <div class='absolute inset-0 bg-gradient-to-br from-[var(--ctx)]/10 via-zinc-950 to-zinc-950'></div>
   </div>

   <!-- ═══ Main Layout ═══════════════════════════════════════════════════════ -->
   <main
      class='min-h-screen flex flex-col lg:flex-row items-center justify-center gap-10 px-6 py-24 max-w-6xl mx-auto'
      transition:name={`image-${id}`}
   >

      <!-- ── Imagen del Proyecto ──────────────────────────────────────────── -->
      <div class='w-full max-w-sm lg:max-w-md shrink-0'>
         <img
            src={`/${id}.jpg`}
            alt={card.title}
            class='w-full rounded-2xl object-cover object-top shadow-2xl ring-1 ring-white/10 hover:scale-[102%] transition-transform duration-300'
         />
      </div>

      <!-- ── Panel de Información ────────────────────────────────────────── -->
      <div class='flex flex-col gap-5 max-w-xl w-full'>

         <!-- Tipo + Rol -->
         <div class='flex flex-wrap items-center gap-3'>
            <span
               class='px-3 py-1 rounded-full text-[10px] font-bold tracking-widest uppercase text-white'
               style={`background-color: ${card.color}35; border: 1px solid ${card.color}70;`}
            >
               {card.type}
            </span>
            <span class='text-xs text-zinc-400 font-medium tracking-wide'>{card.role}</span>
         </div>

         <!-- Título -->
         <h1 class='text-3xl sm:text-4xl font-black leading-tight text-white'>
            {card.title}
         </h1>

         <!-- Descripción -->
         <p class='text-zinc-300 text-sm sm:text-base leading-relaxed'>
            {card.description}
         </p>

         <!-- Highlights -->
         <ul class='flex flex-col gap-2'>
            {card.highlights.map((h) => (
               <li class='flex items-start gap-2.5 text-sm text-zinc-300'>
                  <svg
                     class='mt-0.5 shrink-0'
                     style={`color: ${card.color}`}
                     xmlns='http://www.w3.org/2000/svg' width='16' height='16'
                     viewBox='0 0 24 24' fill='none' stroke='currentColor'
                     stroke-width='2.5' stroke-linecap='round' stroke-linejoin='round'
                  >
                     <path d='M20 6 9 17l-5-5'/>
                  </svg>
                  {h}
               </li>
            ))}
         </ul>

         <!-- Stack -->
         <div class='flex flex-wrap gap-2 pt-1'>
            {card.stack.map((tech) => (
               <span
                  class='px-3 py-1 rounded-full text-xs font-medium text-zinc-200 border tracking-wide'
                  style={`border-color: ${card.color}50; background-color: ${card.color}12;`}
               >
                  {tech}
               </span>
            ))}
         </div>

         <!-- Acciones -->
         <div class='flex items-center gap-5 pt-2'>
            <a
               href='/#projects'
               class='flex items-center gap-2 text-sm font-medium text-zinc-400 hover:text-white transition-colors duration-200'
            >
               <i class={`${buttons[0].back} text-base`}></i>
               Volver
            </a>

            {
               card.github ? (
                  <a
                     href={card.github}
                     target='_blank'
                     rel='noopener noreferrer'
                     class='flex items-center gap-2 px-5 py-2 rounded-full text-sm font-semibold text-white transition-all duration-300 hover:brightness-110 hover:scale-[1.03]'
                     style={`background-color: ${card.color}`}
                  >
                     <i class={`${buttons[0].github} text-base`}></i>
                     Ver Repositorio
                  </a>
               ) : (
                  <span
                     class='flex items-center gap-2 px-5 py-2 rounded-full text-sm font-semibold text-white/30 cursor-not-allowed border border-white/10'
                     title='Repositorio privado o no disponible'
                  >
                     <i class={`${buttons[0].github} text-base`}></i>
                     Repositorio privado
                  </span>
               )
            }
         </div>

      </div>
   </main>
</Layout>

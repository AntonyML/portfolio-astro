---
import Form from "../components/Form.astro";
import Layout from "../layouts/Layout.astro";
import About from "../components/About.astro";
import Navbar from "../components/Navbar.astro";
import Projects from "../components/Projects.astro";
import Separator from "../components/Separator.astro";
import ProfilePicture from "../components/ProfilePicture.astro";
import Footer from "../components/Footer.astro";
import WorkExperience from "../components/WorkExperience.astro";
---

<Layout title="Antony Monge | Portfolio">
   <Navbar />

   <main class="mt-16 scroll-mt-36" id="home">
      <ProfilePicture />
      <Separator />
      <WorkExperience />
      <Separator />
      <Projects />
      <Separator />
      <About />
   </main>

   <!-- Contact modal lives outside main flow (fixed overlay) -->
   <Form />

   <Separator />
   <Footer />
</Layout>

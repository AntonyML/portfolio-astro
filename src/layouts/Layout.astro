---
interface Props {
   title: string;
}

import "../assets/style.css";
const { title } = Astro.props;
import { ViewTransitions } from "astro:transitions";
---

<!doctype html>
<html lang="en" class="scroll-smooth">
   <head>
      <meta charset="UTF-8" />
      <meta name="description" content="Portfolio de Antony Monge — Ingeniero de Software especializado en arquitectura de sistemas, desarrollo empresarial y consultoria tecnica." />
      <meta name="author" content="Antony Monge" />
      <meta name="keywords" content="Antony Monge, Ingeniero de Software, Arquitectura de Software, Clean Architecture, Microservicios, .NET, React, TypeScript, Costa Rica" />
      <meta property="og:title" content="Antony Monge | Portfolio" />
      <meta property="og:description" content="Ingeniero de Software especializado en arquitectura de sistemas, desarrollo empresarial y consultoria tecnica." />
      <meta property="og:type" content="website" />
      <meta name="viewport" content="width=device-width" />
      
      <!--=============== Favicons ===============-->
      <link rel="icon" type="image/png" href="/favicon/favicon-96x96.png" sizes="96x96" />
      <link rel="icon" type="image/svg+xml" href="/favicon/favicon.svg" />
      <link rel="shortcut icon" href="/favicon/favicon.ico" />
      <link rel="apple-touch-icon" sizes="180x180" href="/favicon/apple-touch-icon.png" />
      <meta name="apple-mobile-web-app-title" content="Portfolio" />
      <link rel="manifest" href="/favicon/site.webmanifest" />
      <meta name="theme-color" content="#0a0a0a" />

      <meta name="generator" content={Astro.generator} />

      <!--=============== BoxIcons ===============-->
      <link
         rel="stylesheet"
         href="https://cdn.jsdelivr.net/npm/boxicons@latest/css/boxicons.min.css"
      />

      <title>{title}</title>

      <!--=============== View Transition ===============-->
      <ViewTransitions />
   </head>
   <body class="bg-black text-white">
      <div id="toast" class="toast"></div>

      <slot />
      <script src="../assets/index.js"></script>
   </body>
</html>